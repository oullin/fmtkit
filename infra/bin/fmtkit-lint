#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fmt_ts_lint="${FMTKIT_TS_LINT_SH:-${script_dir}/fmtkit-ts-lint}"

declare -a args=("$@")

if [[ ${#args[@]} -eq 0 ]]; then
	args=(.)
fi

export GIT_CONFIG_COUNT=1
export GIT_CONFIG_KEY_0=safe.directory
export GIT_CONFIG_VALUE_0="*"

"$fmt_ts_lint" "${args[@]}"
