{
	"name": "sidecar",
	"private": true,
	"imports": {
		"#sidecar/ast": "./src/ast.ts",
		"#sidecar/ast.js": "./src/ast.ts",
		"#sidecar/blank-lines": "./src/blank-lines.ts",
		"#sidecar/blank-lines.js": "./src/blank-lines.ts",
		"#sidecar/blank-line-inserter": "./src/blank-line-inserter.ts",
		"#sidecar/blank-line-inserter.js": "./src/blank-line-inserter.ts",
		"#sidecar/body-wrapper": "./src/body-wrapper.ts",
		"#sidecar/body-wrapper.js": "./src/body-wrapper.ts",
		"#sidecar/class-reorder": "./src/class-reorder.ts",
		"#sidecar/class-reorder.js": "./src/class-reorder.ts",
		"#sidecar/declaration-reorder": "./src/declaration-reorder.ts",
		"#sidecar/declaration-reorder.js": "./src/declaration-reorder.ts",
		"#sidecar/drizzle-queries": "./src/drizzle-queries.ts",
		"#sidecar/drizzle-queries.js": "./src/drizzle-queries.ts",
		"#sidecar/expanded-calls": "./src/expanded-calls.ts",
		"#sidecar/expanded-calls.js": "./src/expanded-calls.ts",
		"#sidecar/edits": "./src/edits.ts",
		"#sidecar/edits.js": "./src/edits.ts",
		"#sidecar/format-all": "./src/format-all.ts",
		"#sidecar/format-all.js": "./src/format-all.ts",
		"#sidecar/pass-utils": "./src/pass-utils.ts",
		"#sidecar/pass-utils.js": "./src/pass-utils.ts",
		"#sidecar/files": "./src/files.ts",
		"#sidecar/files.js": "./src/files.ts",
		"#sidecar/fluent-chains": "./src/fluent-chains.ts",
		"#sidecar/fluent-chains.js": "./src/fluent-chains.ts",
		"#sidecar/result": "./src/result.ts",
		"#sidecar/result.js": "./src/result.ts",
		"#sidecar/rules": "./src/rules.ts",
		"#sidecar/rules.js": "./src/rules.ts",
		"#sidecar/segment": "./src/segment.ts",
