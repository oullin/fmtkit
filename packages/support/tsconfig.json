{
	"compilerOptions": {
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "bundler",
		"baseUrl": "./scripts",
		"paths": {
			"@ui/*": ["ui/*"]
		},
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["scripts/**/*.ts", "vite.config.ts"]
}
